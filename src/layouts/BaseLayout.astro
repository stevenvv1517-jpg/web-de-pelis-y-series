---
const { title = "Nexus Stream | Series y Películas Online", activePage = "inicio" } = Astro.props;
import '../styles/style.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/nexus_stream_logo.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <!-- Adsterra: Ventana Emergente (Popunder) -->
    <script src="https://pl29155895.profitablecpmratenetwork.com/0e/07/32/0e0732e0aa56212e2edde854fbcb8529.js"></script>
</head>
<body>
    <header class="navbar">
        <div class="logo" style="display:flex; align-items:center;">
            <a href="/">
                <img src="/images/nexus_stream_logo.png" alt="Nexus Stream Logo" style="height: 50px; border-radius: 8px; cursor: pointer;" />
            </a>
        </div>
        <nav class="nav-links" style="display:flex; align-items:center;">
            <a href="/" class={activePage === 'inicio' ? 'active' : ''}>Inicio/Series</a>
            <a href="/peliculas" class={activePage === 'peliculas' ? 'active' : ''}>Películas</a>
            <a href="/#buzon">Buzón</a>
            <div class="search-container" style="position: relative;">
                <input id="global-search-input" type="text" placeholder="Buscar..." style="background:transparent; border:none; color:white; outline:none; padding:5px; width:150px;" />
                <button style="background:transparent; border:none; color:var(--text-secondary); cursor:pointer; font-size:16px;">🔍</button>
                <div id="search-results-dropdown" class="search-results-dropdown"></div>
            </div>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        <p>&copy; <span id="admin-trigger" style="cursor: default;">2026 Nexus Stream</span>. Todos los derechos reservados. No almacenamos material con derechos de autor.</p>
        <p style="font-size: 12px; margin-top: 10px;">
            <a href="#" style="color: var(--text-secondary);">Política de Privacidad</a> | 
            <a href="#" style="color: var(--text-secondary);">Términos y Condiciones</a>
        </p>
    </footer>

    <!-- ===== INTERSTICIAL DE ANUNCIO GLOBAL ===== -->
    <div id="ad-interstitial" style="
        display: none; position: fixed; inset: 0; z-index: 99999;
        background: rgba(5,5,15,0.97); backdrop-filter: blur(10px);
        flex-direction: column; align-items: center; justify-content: center;
        font-family: 'Outfit', sans-serif;
    ">
        <div style="text-align: center; max-width: 600px; padding: 30px;">
            <p style="color: rgba(255,255,255,0.4); font-size: 13px; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;">Patrocinado por</p>
            <!-- Espacio del anuncio nativo dentro del intersticial -->
            <div style="min-height: 120px; background: rgba(255,255,255,0.03); border-radius: 16px; border: 1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center; margin-bottom: 30px; overflow:hidden;" id="ad-interstitial-slot">
                <p style="color: rgba(255,255,255,0.2);">Anuncio</p>
            </div>
            <div style="display: flex; align-items: center; justify-content: center; gap: 20px;">
                <div id="ad-countdown" style="
                    width: 60px; height: 60px; border-radius: 50%;
                    border: 3px solid var(--accent, #1e90ff);
                    display: flex; align-items: center; justify-content: center;
                    font-size: 24px; font-weight: 800; color: white;
                ">5</div>
                <div>
                    <p style="color: white; font-size: 18px; font-weight: 600; margin: 0;">Cargando contenido...</p>
                    <p style="color: rgba(255,255,255,0.4); font-size: 13px; margin: 5px 0 0;">El contenido cargará automáticamente</p>
                </div>
            </div>
            <button id="ad-skip-btn" onclick="window.__adSkip()" style="
                display: none; margin-top: 25px; background: rgba(255,255,255,0.08);
                border: 1px solid rgba(255,255,255,0.15); color: white; padding: 10px 30px;
                border-radius: 30px; cursor: pointer; font-size: 14px; transition: 0.2s;
            ">Saltar anuncio →</button>
        </div>
    </div>

    <script is:inline>
        document.getElementById('admin-trigger').addEventListener('dblclick', () => {
            const pass = prompt("Acceso de Administrador. Ingrese clave:");
            if(pass === "admin123") {
                window.location.href = "/admin";
            }
        });
    </script>

    <script is:inline>
        // Sistema Global de Favoritos
        document.addEventListener('click', (e) => {
            const btn = e.target.closest('.fav-btn');
            if (!btn) return;

            e.stopPropagation(); // Evitar que el click en el corazón active el link de la card
            
            const id = btn.dataset.id;
            const title = btn.dataset.title;
            const img = btn.dataset.img;
            const url = btn.dataset.url;

            let favs = JSON.parse(localStorage.getItem('nexus_favs') || '[]');
            const index = favs.findIndex(f => f.id === id);

            if (index > -1) {
                favs.splice(index, 1);
                btn.classList.remove('active');
            } else {
                favs.push({ id, title, img, url });
                btn.classList.add('active');
            }

            localStorage.setItem('nexus_favs', JSON.stringify(favs));
            
            // Disparar evento para que otras partes de la UI se actualicen (como la home)
            document.dispatchEvent(new CustomEvent('favsUpdated'));
        });

        // Marcar botones activos al cargar
        function syncFavButtons() {
            const favs = JSON.parse(localStorage.getItem('nexus_favs') || '[]');
            const ids = favs.map(f => f.id);
            document.querySelectorAll('.fav-btn').forEach(btn => {
                if (ids.includes(btn.dataset.id)) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        }
        
        document.addEventListener('DOMContentLoaded', syncFavButtons);
        // También ejecutar después de navegar en Astro (si usas View Transitions, pero aquí parece navegación normal)
        syncFavButtons();
    </script>

    <script is:inline src="/script.js"></script>
    <!-- Adsterra: Bar Social -->
    <script src="https://pl29155894.profitablecpmratenetwork.com/67/d6/10/67d610375ac0c428a2717ef95fc12fe0.js"></script>

    <script is:inline>
        // ===== SISTEMA DE INTERSTICIAL =====
        window.__showInterstitial = function(callback) {
            const overlay = document.getElementById('ad-interstitial');
            const countdownEl = document.getElementById('ad-countdown');
            const skipBtn = document.getElementById('ad-skip-btn');

            overlay.style.display = 'flex';
            let seconds = 5;
            countdownEl.textContent = seconds;
            skipBtn.style.display = 'none';

            const interval = setInterval(() => {
                seconds--;
                countdownEl.textContent = seconds;
                if (seconds <= 3) skipBtn.style.display = 'inline-block';
                if (seconds <= 0) {
                    clearInterval(interval);
                    overlay.style.display = 'none';
                    callback();
                }
            }, 1000);

            window.__adSkip = function() {
                clearInterval(interval);
                overlay.style.display = 'none';
                callback();
            };
        };

        // Interceptar clicks en cards para mostrar intersticial antes de navegar
        document.addEventListener('click', (e) => {
            if (e.target.closest('.fav-btn')) return;
            if (e.target.closest('.play-btn')) return;

            const card = e.target.closest('.card:not(.disabled)');
            if (!card) return;

            const onclickAttr = card.getAttribute('onclick');
            if (!onclickAttr || !onclickAttr.includes('location')) return;

            e.preventDefault();
            e.stopImmediatePropagation();

            const match = onclickAttr.match(/href='([^']+)'/);
            if (!match) return;
            const url = match[1];

            window.__showInterstitial(() => {
                window.location.href = url;
            });
        }, true);
    </script>
</body>
</html>
