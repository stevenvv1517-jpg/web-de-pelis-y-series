---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ninjago: Maestros del Spinjitzu | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.3)), url('/images/ninjago_hero.jpg') center/cover;">
        <div class="hero-content">
            <span class="badge">Serie Completa</span>
            <h1>LEGO Ninjago</h1>
            <p>Sigue las aventuras de los maestros del Spinjitzu desde sus humildes comienzos hasta las épicas batallas por el destino de los reinos.</p>
        </div>
    </section>

    <!-- Catálogo de Temporadas -->
    <section class="content-section">
        <div class="section-header">
            <h2>Cronología de Ninjago</h2>
        </div>

        <div class="grid-container">
            <!-- Portada Temp 0 (Pilotos) -->
            <div class="card" onclick="window.location.href='/temporada0'" style="cursor: pointer; border: 2px solid #ffffff; border-radius: 20px;">
                <div class="fav-btn" data-id="ninjago-temp0" data-title="Día del Ninja (Temporada 0)" data-img="/images/ninjago_temp0.jpg" data-url="/temporada0"><i class="fa fa-heart"></i></div>
                <div class="card-image" style="background-image: url('/images/ninjago_temp0.jpg'); height: 350px;">
                    <div class="overlay">
                        <span style="background: white; color: black; padding: 10px 20px; border-radius: 20px; font-weight: bold;">VER PILOTOS</span>
                    </div>
                </div>
                <div class="season-title" style="color: #ffffff;">
                    DÍA DEL NINJA (TEMPORADA 0)
                </div>
            </div>

            <!-- Portada Temp 1 -->
            <div class="card" onclick="window.location.href='/temporada1'" style="cursor: pointer;">
                <div class="fav-btn" data-id="ninjago-temp1" data-title="El Ascenso de las Serpientes (Temporada 1)" data-img="/images/ninjago_temp1.jpg" data-url="/temporada1"><i class="fa fa-heart"></i></div>
                <div class="card-image" style="background-image: url('/images/ninjago_temp1.jpg'); height: 350px;">
                    <div class="overlay">
                        <span style="border: 2px solid white; padding: 10px 20px; border-radius: 20px; color: white; font-weight: bold;">VER CAPÍTULOS</span>
                    </div>
                </div>
                <div class="season-title" style="color: #2ecc71;">
                    EL ASCENSO DE LAS SERPIENTES (TEMPORADA 1)
                </div>
            </div>

            <!-- Portada Temp 2 -->
            <div class="card" onclick="window.location.href='/temporada2'" style="cursor: pointer;">
                <div class="fav-btn" data-id="ninjago-temp2" data-title="El Legado del Ninja Verde (Temporada 2)" data-img="/images/ninjago_temp2.jpg" data-url="/temporada2"><i class="fa fa-heart"></i></div>
                <div class="card-image" style="background-image: url('/images/ninjago_temp2.jpg'); height: 350px;">
                    <div class="overlay">
                        <span style="border: 2px solid white; padding: 10px 20px; border-radius: 20px; color: white; font-weight: bold;">VER CAPÍTULOS</span>
