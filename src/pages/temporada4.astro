---
import BaseLayout from '../layouts/BaseLayout.astro';

const episodes = [
    { num: 1, title: "La Invitación", driveId: "1ccaYHisKkzysX4LbUgmgRC4cVNURWoCo", desc: "Tras perder a Zane, los Ninja se reúnen al descubrir que está vivo." },
    { num: 2, title: "Solo uno puede prevalecer", driveId: "1Fd8mQXGqwb5I7lVFW8w3KAb8iVFZTNNA", desc: "Los Ninja llegan a la isla del Maestro Chen." },
    { num: 3, title: "Versus", driveId: "1KdTAHLKXmh6zbhAv9I6H3cfZumMi1Hx5", desc: "Comienzan los duelos directos elementales." },
    { num: 4, title: "Ninja sobre ruedas", driveId: "15KCrqhffnFIv8EncP2ccibiIAK4gzVDv", desc: "Carrera de patines extrema entre los maestros." },
    { num: 5, title: "Espía por espía", driveId: "1hRcydtFVT3lr4vVlau2VQ3VuthrclS8j", desc: "Los Ninja intentan infiltrarse en el palacio." },
    { num: 6, title: "El Hechizo", driveId: "1H8fERcQ8I69WuUiW4GWLd0GfDHmMCw8k", desc: "Chen revela su plan de transformación Anacondrai." },
    { num: 7, title: "El Elemento Olvidado", driveId: "1uq66RSCE4MiyrVm_VbBPYOnPPY0FRGvn", desc: "Skylor revela su verdadera identidad." },
    { num: 8, title: "El Día del Dragón", driveId: "1HlD3AKjTKSuH8POIEHmI3NK9iR3ijrAW", desc: "Los Ninja desbloquean sus dragones elementales." },
    { num: 9, title: "El Mayor de los Temores", driveId: "13mUK0MVL9NVMIwPUukx3Izx6eG40ccL2", desc: "El ejército de Chen inicia la invasión." },
    { num: 10, title: "El Corredor de los Ancianos", driveId: "1cr0WCguuv8HI7GfQ9mnabiH-k0__keHB", desc: "Sacrificio final para expulsar a los Anacondrai." }
];
---

<BaseLayout title="Ninjago Temporada 4: El Torneo de los Elementos | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.4)), url('/images/ninjago_temp4.jpg') center/cover;">
        <div class="hero-content">
            <span class="badge" style="background: #e67e22; color: white;">Temporada 4</span>
            <h1>El Torneo de los Elementos</h1>
            <p>Los Ninja viajan a una isla misteriosa para participar en el torneo del Maestro Chen, donde descubrirán nuevos aliados y la verdad sobre los Anacondrai.</p>
        </div>
    </section>

    <!-- Lista de Episodios con Portadas -->
    <section class="content-section">
        <div class="section-header">
            <h2>Episodios (10)</h2>
        </div>

        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {episodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('/images/ninjago_temp4.jpg');`}>
                        <div class="ep-overlay">
                            <span class="ep-badge">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Reproductor -->
    <section class="content-section" id="player" style="padding-top: 0;">
        <div class="section-header">
            <h2 id="player-title" style="border-left: 4px solid #e67e22; padding-left: 15px;">Selecciona un episodio</h2>
        </div>
        <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
            <div id="video-wrapper" class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); flex-direction: column;">
                    <i class="fa fa-play-circle" style="font-size: 64px; margin-bottom: 20px; color: #e67e22;"></i>
                    <p>¡Que el torneo comience!</p>
                </div>
            </div>
            <div class="series-controls" style="padding: 20px; background: rgba(0,0,0,0.5); display: flex; justify-content: center; gap: 20px;">
                <a id="download-link" href="#" target="_blank" class="btn-primary" style="background: #e67e22; color: white;"><i class="fa fa-download"></i> Descargar Episodio</a>
            </div>
        </div>
    </section>

    <script is:inline define:vars={{ episodes }}>
        window.updatePlayer = function(index, title, driveId) {
            document.getElementById('player-title').innerText = `Reproduciendo: Ep ${index + 1} - ${title}`;
            document.getElementById('video-wrapper').innerHTML = `<iframe src="https://drive.google.com/file/d/${driveId}/preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" allowfullscreen></iframe>`;
            document.getElementById('download-link').href = `https://drive.google.com/file/d/${driveId}/view?usp=sharing`;
            
            if (window.trackVideoView) window.trackVideoView();
            window.scrollTo({ top: document.getElementById('player').offsetTop - 100, behavior: 'smooth' });
        }
    </script>

    <style>
        .episode-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            transition: 0.3s;
        }
        .episode-card:hover {
            transform: translateY(-5px);
            border-color: #e67e22;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .ep-thumbnail {
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .ep-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: 0.3s;
        }
        .episode-card:hover .ep-overlay { opacity: 1; background: rgba(0,0,0,0.2); }
        .ep-badge {
            position: absolute;
            top: 10px; left: 10px;
            background: #e67e22;
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }
        .ep-overlay i { font-size: 40px; color: white; }
        .ep-details { padding: 15px; }
        .ep-details h4 { font-size: 15px; margin-bottom: 5px; color: white; }
        .ep-details p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</BaseLayout>
