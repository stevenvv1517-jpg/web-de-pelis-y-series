---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="El hombre araña (2002) | Nexus Stream" activePage="peliculas">
    <div class="movie-detail-container" style="padding-top: 100px; min-height: 100vh; background: linear-gradient(to bottom, rgba(10,10,15,0.8), var(--bg-dark)), url('https://image.tmdb.org/t/p/original/zQ8AxTPiCiS5nnwXpwTBPBHSaa5.jpg') center/cover fixed;">
        <div class="content-section">
            <div class="movie-header" style="display: flex; gap: 40px; background: var(--glass-bg); padding: 40px; border-radius: 24px; border: 1px solid var(--glass-border); backdrop-filter: blur(20px);">
                <div class="movie-poster" style="flex: 0 0 300px;">
                    <img src="https://image.tmdb.org/t/p/w300//mVOCqKvJZvpA1oXPk35OLBsgcPF.jpg" alt="Spider-Man Poster" style="width: 100%; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);" />
                </div>
                <div class="movie-info" style="flex: 1;">
                    <h1 style="font-size: 48px; margin-bottom: 10px;">El hombre araña</h1>
                    <div class="meta-tags" style="display: flex; gap: 15px; margin-bottom: 20px;">
                        <span class="badge">Pelicula</span>
                        <span style="color: var(--text-secondary);">2h 1m</span>
                        <span style="color: var(--text-secondary);">2002</span>
                    </div>
                    <div class="genres" style="margin-bottom: 20px; color: var(--accent); font-weight: 600;">
                        Acción, Ciencia ficción
                    </div>
                    <div class="rating-container" style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px;">
                        <div class="rating-circle" style="background: rgba(0,0,0,0.5); border: 4px solid forestgreen; border-radius: 50%; width: 60px; height: 60px; display: flex; justify-content: center; align-items: center; font-weight: 800; font-size: 14px;">
                            73.6%
                        </div>
                        <div class="stars" style="color: #ffc107; font-size: 20px;">
                            <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star-half-o"></i> <span style="color: var(--text-secondary); font-size: 14px; margin-left: 10px;">(20493)</span>
                        </div>
                    </div>
                    <p style="font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin-bottom: 40px;">
                        Cuando es mordido por una araña genéticamente modificada, un estudiante de secundaria nerd, tímido y torpe, adquiere habilidades parecidas a las de una araña que eventualmente debe usar para luchar contra el mal como un superhéroe después de que la tragedia cae sobre su familia.
                    </p>
                    
                    <div class="action-buttons" style="display: flex; gap: 20px;">
                        <a href="https://www.youtube.com/watch?v=kg3Q63gzF6I" target="_blank" class="btn-secondary" style="padding: 12px 25px; text-decoration: none; border-radius: 30px; display: flex; align-items: center; gap: 10px;">
                            <i class="fa fa-youtube-play"></i> <p> Ver Trailer</p>
                        </a>
                        <a href="#player" class="btn-primary" style="padding: 12px 40px; text-decoration: none; border-radius: 30px; display: flex; align-items: center; gap: 10px;">
                            <i class="fa fa-play"></i> <p> Reproducir</p>
                        </a>
                        <a href="#downloads" class="btn-secondary" style="padding: 12px 25px; text-decoration: none; border-radius: 30px; display: flex; align-items: center; gap: 10px;">
                            <i class="fa fa-download"></i> <p> Descargar</p>
                        </a>
                    </div>
                </div>
            </div>

            <div id="player" style="margin-top: 60px;">
                <div class="section-header">
                    <h2 style="border-left: 4px solid var(--accent); padding-left: 15px;">Reproductor Premium</h2>
                </div>
                <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
                    <div class="player-options" style="display: flex; background: rgba(0,0,0,0.5); padding: 15px; gap: 10px; border-bottom: 1px solid var(--glass-border);">
                        <button class="server-btn active" style="background: var(--accent); color: white; border: none; padding: 10px 25px; border-radius: 8px; cursor: pointer; font-weight: 600;">Opción 1 (Drive)</button>
                    </div>
                    <div class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                        <iframe 
                            src="https://drive.google.com/file/d/0ByibEzjq_Q9Lb3pKamk2am1aOG8/preview?resourcekey=0-gVbMTU_tmudnIx_ZQyinpg" 
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" 
                            allowfullscreen>
                        </iframe>
                    </div>
                </div>
            </div>

            <div id="downloads" style="margin-top: 60px;">
                <div class="section-header">
                    <h2>Descargas</h2>
                </div>
                <div class="downloads-table" style="background: var(--glass-bg); border-radius: 20px; border: 1px solid var(--glass-border); overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead style="background: rgba(255,255,255,0.05);">
                            <tr>
                                <th style="padding: 20px;">SERVIDOR</th>
                                <th style="padding: 20px;">IDIOMA</th>
                                <th style="padding: 20px;">CALIDAD</th>
                                <th style="padding: 20px;">ENLACE</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-top: 1px solid var(--glass-border);">
                                <td style="padding: 20px;">Google Drive</td>
                                <td style="padding: 20px;">Español Latino</td>
                                <td style="padding: 20px;">HD</td>
                                <td style="padding: 20px;"><a href="https://drive.google.com/file/d/0ByibEzjq_Q9Lb3pKamk2am1aOG8/view?usp=sharing&resourcekey=0-gVbMTU_tmudnIx_ZQyinpg" target="_blank" style="color: var(--accent); font-weight: bold; text-decoration: none;">DESCARGAR</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    @media (max-width: 992px) {
        .movie-header {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .meta-tags, .rating-container, .action-buttons {
            justify-content: center;
        }
        .movie-poster {
            flex: 0 0 auto;
            max-width: 300px;
        }
    }
</style>
