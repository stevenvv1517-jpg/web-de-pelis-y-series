---
import BaseLayout from '../layouts/BaseLayout.astro';

const episodes = [
    { num: 1, title: "Infames", driveId: "1slkXT5qLQfXWvhriTeUu1gjQq3s4kMEZ", desc: "Los Ninja son incriminados por crímenes que no cometieron." },
    { num: 2, title: "Enemigo público número uno", driveId: "1TWg68ROH26gZ9WVA_-i_BeBlhj2G_VPm", desc: "Los Ninja huyen de la justicia mientras Nadakhan regresa." },
    { num: 3, title: "Encerrados", driveId: "1KS44gFTE6OpbJG-PnT7QPMwo0El6t7ZW", desc: "Los Ninja terminan en la prisión de Kryptarium." },
    { num: 4, title: "El ascenso de la Fortaleza", driveId: "1qL8YE3O6DtDAuSe9nKqkt4fVV-1KDjjE", desc: "Nadakhan reconstruye su barco volador." },
    { num: 5, title: "Deseos concedidos", driveId: "17oPHM_Fy0q7vF92jLfXLkVjGqjon3DcD", desc: "Los piratas atacan la ciudad mientras Jay usa sus deseos." },
    { num: 6, title: "Cena con Nadakhan", driveId: "1L--5qUI4mj0TgYOJa5msHUW5lDF-Eii6", desc: "Jay es capturado en la fortaleza pirata." },
    { num: 7, title: "Deseos fallidos", driveId: "1xsInii5mVfrbMS5PO7Ia9xdvagBEsEn8", desc: "Viaje a la isla para encontrar el veneno de la Viuda." },
    { num: 8, title: "El último recurso", driveId: "1DA7D6N7oqLdy9wu9kf21JO-kdIuY9DKO", desc: "Nya y Jay se ocultan en el faro de Zane." },
    { num: 9, title: "Operación Tierra a la Vista", driveId: "1QNDQFUodBeDA71MfFs4z5F6YAeSX4IPv", desc: "Escape desde el interior de la espada mágica." },
    { num: 10, title: "El camino a casa", driveId: "1hh0kd40O-wUFguV7FjkDbL0s-JAQe-jM", desc: "Jay usa su último deseo para revertir el tiempo." }
];
---

<BaseLayout title="Ninjago Temporada 6: Skybound | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.4)), url('https://lh3.googleusercontent.com/sitesv/AA5AbUA3Oyr0fon6E3nY5MjOtGDGYV6Tq8fIZvcbcw5LvaQkWYfxhttCt3feA4zMRO0FQSpGKs-N4XuTFAX7dGvWMptzRV0R0cTrBl0Zc9N3x-KVU5vsLpMdLhL6lQqLlPWxBgTLsS0Jmp0J6p9PCAWaLac_BnR8gNwM1qjhHLlCRmVWwCIXMsnfaIJ918kA80JFHDLvuuLgteQHB-4nTyYOscp1NJiaX5d-H3XuLc0=w1280') center/cover;">
        <div class="hero-content">
            <span class="badge" style="background: #ff9f43; color: white;">Temporada 6</span>
            <h1>Los Piratas del Aire (Skybound)</h1>
            <p>Nadakhan el Genio es liberado y busca casarse con Nya para obtener deseos infinitos. Los Ninja deben detener su fortaleza flotante antes de que Ninjago sea destruido.</p>
        </div>
    </section>

    <!-- Lista de Episodios con Portadas -->
    <section class="content-section">
        <div class="section-header">
            <h2>Episodios (10)</h2>
        </div>

        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {episodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('https://lh3.googleusercontent.com/sitesv/AA5AbUA3Oyr0fon6E3nY5MjOtGDGYV6Tq8fIZvcbcw5LvaQkWYfxhttCt3feA4zMRO0FQSpGKs-N4XuTFAX7dGvWMptzRV0R0cTrBl0Zc9N3x-KVU5vsLpMdLhL6lQqLlPWxBgTLsS0Jmp0J6p9PCAWaLac_BnR8gNwM1qjhHLlCRmVWwCIXMsnfaIJ918kA80JFHDLvuuLgteQHB-4nTyYOscp1NJiaX5d-H3XuLc0=w1280');`}>
                        <div class="ep-overlay">
                            <span class="ep-badge">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Reproductor -->
    <section class="content-section" id="player" style="padding-top: 0;">
        <div class="section-header">
            <h2 id="player-title" style="border-left: 4px solid #ff9f43; padding-left: 15px;">Selecciona un episodio</h2>
        </div>
        <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
            <div id="video-wrapper" class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); flex-direction: column;">
                    <i class="fa fa-play-circle" style="font-size: 64px; margin-bottom: 20px; color: #ff9f43;"></i>
                    <p>Ten cuidado con lo que deseas...</p>
                </div>
            </div>
            <div class="series-controls" style="padding: 20px; background: rgba(0,0,0,0.5); display: flex; justify-content: center; gap: 20px;">
                <a id="download-link" href="#" target="_blank" class="btn-primary" style="background: #ff9f43; color: white;"><i class="fa fa-download"></i> Descargar Episodio</a>
            </div>
        </div>
    </section>

    <script is:inline define:vars={{ episodes }}>
        window.updatePlayer = function(index, title, driveId) {
            document.getElementById('player-title').innerText = `Reproduciendo: Ep ${index + 1} - ${title}`;
            document.getElementById('video-wrapper').innerHTML = `<iframe src="https://drive.google.com/file/d/${driveId}/preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" allowfullscreen></iframe>`;
            document.getElementById('download-link').href = `https://drive.google.com/file/d/${driveId}/view?usp=sharing`;
            
            if (window.trackVideoView) window.trackVideoView();
            window.scrollTo({ top: document.getElementById('player').offsetTop - 100, behavior: 'smooth' });
        }
    </script>

    <style>
        .episode-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            transition: 0.3s;
        }
        .episode-card:hover {
            transform: translateY(-5px);
            border-color: #ff9f43;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .ep-thumbnail {
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .ep-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: 0.3s;
        }
        .episode-card:hover .ep-overlay { opacity: 1; background: rgba(0,0,0,0.2); }
        .ep-badge {
            position: absolute;
            top: 10px; left: 10px;
            background: #ff9f43;
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }
        .ep-overlay i { font-size: 40px; color: white; }
        .ep-details { padding: 15px; }
        .ep-details h4 { font-size: 15px; margin-bottom: 5px; color: white; }
        .ep-details p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</BaseLayout>
