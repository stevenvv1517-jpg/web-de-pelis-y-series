---
import BaseLayout from '../layouts/BaseLayout.astro';

const episodes = [
    { num: 1, title: "La Oscuridad se aproxima", driveId: "1EEiNuX8bMwRnWICaMk94QBrZcnvnr6MI", desc: "Una extraña nube negra comienza a cubrir Ninjago, convirtiendo a todo el que toca en piedra. Los Ninja liberan a Garmadon." },
    { num: 2, title: "Hacia la Brecha", driveId: "1eiFNRz3WEhIa2ohK8HbNQdW5qQfzEUXh", desc: "Los Ninja se adentran en la oscuridad para intentar detener el avance de los Oni y salvar a los ciudadanos." },
    { num: 3, title: "La Caída", driveId: "1BlsxhJWs04WGgJChywF8J7RDHV9DFLXr", desc: "La resistencia se debilita mientras los Oni invaden el corazón de la ciudad. El equipo debe prepararse para su última defensa." },
    { num: 4, title: "Fin del Juego", driveId: "1YTZvKohuU0Qy_6w3-44ITcB9lhjbnR6a", desc: "Los Ninja utilizan el Tornado de la Creación en una batalla épica para disipar la oscuridad para siempre." }
];
---

<BaseLayout title="Ninjago Temporada 10: La Marcha de los Oni | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.4)), url('/images/ninjago_temp10.jpg') center/cover;">
        <div class="hero-content">
            <span class="badge" style="background: #6c5ce7; color: white;">Temporada 10</span>
            <h1>La Marcha de los Oni</h1>
            <p>El final de una era. Ninjago City enfrenta su hora más oscura cuando una nube de destrucción puramente malvada invade la ciudad. Los Ninja deben unirse a su mayor enemigo para sobrevivir.</p>
        </div>
    </section>

    <!-- Lista de Episodios con Portadas Inteligentes -->
    <section class="content-section">
        <div class="section-header">
            <h2>Episodios Finales (4)</h2>
        </div>

        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {episodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('/images/ninjago_temp10.jpg');`}>
                        <div class="ep-overlay">
                            <span class="ep-badge">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Reproductor -->
    <section class="content-section" id="player" style="padding-top: 0;">
        <div class="section-header">
            <h2 id="player-title" style="border-left: 4px solid #6c5ce7; padding-left: 15px;">Selecciona un episodio</h2>
        </div>
        <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
            <div id="video-wrapper" class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); flex-direction: column;">
                    <i class="fa fa-play-circle" style="font-size: 64px; margin-bottom: 20px; color: #6c5ce7;"></i>
                    <p>La batalla definitiva comienza aquí</p>
                </div>
            </div>
            <div class="series-controls" style="padding: 20px; background: rgba(0,0,0,0.5); display: flex; justify-content: center; gap: 20px;">
                <a id="download-link" href="#" target="_blank" class="btn-primary" style="background: #6c5ce7; color: white;"><i class="fa fa-download"></i> Descargar Episodio</a>
            </div>
        </div>
    </section>

    <script is:inline define:vars={{ episodes }}>
        window.updatePlayer = function(index, title, driveId) {
            document.getElementById('player-title').innerText = `Reproduciendo: Ep ${index + 1} - ${title}`;
            document.getElementById('video-wrapper').innerHTML = `<iframe src="https://drive.google.com/file/d/${driveId}/preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" allowfullscreen></iframe>`;
            document.getElementById('download-link').href = `https://drive.google.com/file/d/${driveId}/view?usp=sharing`;
            
            if (window.trackVideoView) window.trackVideoView();
            window.scrollTo({ top: document.getElementById('player').offsetTop - 100, behavior: 'smooth' });
        }
    </script>

    <style>
        .episode-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            transition: 0.3s;
        }
        .episode-card:hover {
            transform: translateY(-5px);
            border-color: #6c5ce7;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .ep-thumbnail {
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .ep-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: 0.3s;
        }
        .episode-card:hover .ep-overlay { opacity: 1; background: rgba(0,0,0,0.2); }
        .ep-badge {
            position: absolute;
            top: 10px; left: 10px;
            background: #6c5ce7;
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }
        .ep-overlay i { font-size: 40px; color: white; }
        .ep-details { padding: 15px; }
        .ep-details h4 { font-size: 15px; margin-bottom: 5px; color: white; }
        .ep-details p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</BaseLayout>
