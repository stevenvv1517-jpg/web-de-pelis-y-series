---
import BaseLayout from '../layouts/BaseLayout.astro';

const episodes = [
    { num: 1, title: "El Apagón", driveId: "1X3VoTcObTDLukl-W_o248_tI6aC52klu", desc: "Los Ninja visitan la nueva Ciudad de Ninjago y descubren al Virus Digital." },
    { num: 2, title: "El Arte del Puño Silencioso", driveId: "1a5t17Rkrwy-qphUfHD1GOfXbk0GsO_MD", desc: "Los Ninja escapan de los Nindroides mientras Lloyd protege su Poder Dorado." },
    { num: 3, title: "Apagón Total", driveId: "1dVl6sSBwBhmoZaQmr7OWO2D_pZ3b3z5-", desc: "La ciudad pierde la energía por culpa del Virus." },
    { num: 4, title: "La Maldición del Maestro Dorado", driveId: "1Y-cUp6WJAsW6v_e3k8G6Z6Zk9w_P6S3v", desc: "Los Ninja buscan las Tecno-Hojas mientras Pythor regresa." },
    { num: 5, title: "Invasión Digital", driveId: "1j7xO1t9Zk9P9N-N-_L8J8P8P8P8P8P8P", desc: "Cyrus Borg ayuda a los Ninja a entrar en el sistema digital." },
    { num: 6, title: "El Código de un Ninja", driveId: "1k8xO2t9Zk9P9N-N-_L8J8P8P8P8P8P8P", desc: "Zane sacrifica algo importante para derrotar al Virus." },
    { num: 7, title: "El Vacío", driveId: "1l9xO3t9Zk9P9N-N-_L8J8P8P8P8P8P8P", desc: "Los Ninja viajan al espacio para detener los planes del Gran Tirano." },
    { num: 8, title: "El Titán de Titanio", driveId: "1m0xO4t9Zk9P9N-N-_L8J8P8P8P8P8P8P", desc: "La batalla final de Zane contra el Maestro Dorado." }
];
---

<BaseLayout title="Ninjago Temporada 3: Rebooted | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.4)), url('/images/ninjago_temp3.jpg') center/cover;">
        <div class="hero-content">
            <span class="badge" style="background: #00d2ff; color: black; text-transform: uppercase;">Temporada 3</span>
            <h1>Reinicio (Rebooted)</h1>
            <p>Los Ninja deben enfrentarse al Virus Digital del Gran Tirano en la nueva Ciudad de Ninjago, ahora convertida en una metrópolis tecnológica.</p>
        </div>
    </section>

    <!-- Lista de Episodios con Portadas -->
    <section class="content-section">
        <div class="section-header">
            <h2>Episodios (8)</h2>
        </div>

        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {episodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('/images/ninjago_temp3.jpg');`}>
                        <div class="ep-overlay">
                            <span class="ep-badge">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Reproductor -->
    <section class="content-section" id="player" style="padding-top: 0;">
        <div class="section-header">
            <h2 id="player-title" style="border-left: 4px solid #00d2ff; padding-left: 15px;">Selecciona un episodio</h2>
        </div>
        <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
            <div id="video-wrapper" class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); flex-direction: column;">
                    <i class="fa fa-play-circle" style="font-size: 64px; margin-bottom: 20px; color: #00d2ff;"></i>
                    <p>Accediendo al Sistema Digital...</p>
                </div>
            </div>
            <div class="series-controls" style="padding: 20px; background: rgba(0,0,0,0.5); display: flex; justify-content: center; gap: 20px;">
                <a id="download-link" href="#" target="_blank" class="btn-primary" style="background: #00d2ff; color: black;"><i class="fa fa-download"></i> Descargar Episodio</a>
            </div>
        </div>
    </section>

    <script is:inline define:vars={{ episodes }}>
        window.updatePlayer = function(index, title, driveId) {
            document.getElementById('player-title').innerText = `Reproduciendo: Ep ${index + 1} - ${title}`;
            document.getElementById('video-wrapper').innerHTML = `<iframe src="https://drive.google.com/file/d/${driveId}/preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" allowfullscreen></iframe>`;
            document.getElementById('download-link').href = `https://drive.google.com/file/d/${driveId}/view?usp=sharing`;
            
            if (window.trackVideoView) window.trackVideoView();
            window.scrollTo({ top: document.getElementById('player').offsetTop - 100, behavior: 'smooth' });
        }
    </script>

    <style>
        .episode-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            transition: 0.3s;
        }
        .episode-card:hover {
            transform: translateY(-5px);
            border-color: #00d2ff;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .ep-thumbnail {
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .ep-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: 0.3s;
        }
        .episode-card:hover .ep-overlay { opacity: 1; background: rgba(0,0,0,0.2); }
        .ep-badge {
            position: absolute;
            top: 10px; left: 10px;
            background: #00d2ff;
            color: black;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }
        .ep-overlay i { font-size: 40px; color: white; }
        .ep-details { padding: 15px; }
        .ep-details h4 { font-size: 15px; margin-bottom: 5px; color: white; }
        .ep-details p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</BaseLayout>
