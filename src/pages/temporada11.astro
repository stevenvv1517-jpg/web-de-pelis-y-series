---
import BaseLayout from '../layouts/BaseLayout.astro';

const fireEpisodes = [
    { num: 1, title: "Potencial Desperdiciado", driveId: "1OxsumH3hn19f7vD5XZ1LOqiFwMkWUC6j", desc: "Tras la paz, los Ninja se han vuelto perezosos y el Maestro Wu los pone a prueba." },
    { num: 2, title: "En Busca de una Misión", driveId: "11m6P04oBZegBxCi_OZvPtp7P_K2wYozA", desc: "El equipo decide explorar una pirámide antigua para encontrar una nueva aventura." },
    { num: 3, title: "Una Salida de Arena", driveId: "17dwVhd1H8XsrmmTH_k0rPMdDw_JOXaMA", desc: "Los Ninja quedan atrapados en la pirámide y deben resolver acertijos para escapar." },
    { num: 4, title: "El Ataque de la Serpiente", driveId: "1gZeC_lBKsQ7qzXzdDrnYOvoDz3V84hLW", desc: "Aspheera es liberada y busca venganza usando fuego." },
    { num: 5, title: "La Ciudad de las Serpientes", driveId: "1orhv7dczSr5jD-fENb1TtqolC1S10YzV", desc: "El equipo viaja al subsuelo para detener el avance del ejército de Aspheera." },
    { num: 6, title: "Las Noticias Nunca Duermen", driveId: "1I8gBRUDyXcAqH9-j5xCMk-Y_oYy6BH9W", desc: "Nelson y Antonia intentan repartir periódicos en medio de la invasión." },
    { num: 7, title: "Ninja vs. Serpiente", driveId: "1h0KlZGJ9xnzm9Qng7FqYgO4SzoPaGF8T", desc: "Aspheera ataca el Monasterio para obtener los Pergaminos Prohibidos." },
    { num: 8, title: "Snaketastrophy", driveId: "1HJdcNFLYur-Qumja-4GocKCGrPX-_Nw5", desc: "Las serpientes de fuego causan el caos mientras los Ninja intentan proteger la ciudad." },
    { num: 9, title: "Impotente", driveId: "1cJ1kiSG5y0mKjlXgwJz5ITuTV3BTETIv", desc: "Aspheera logra robar el poder elemental de Kai." },
    { num: 10, title: "Antiguos Tiempos", driveId: "1B39oZEcWpHLCeXfd7LACEjtWpsLRxkSn", desc: "Se muestra la historia de juventud de Wu y Garmadon." },
    { num: 11, title: "Nunca Confíes en una Serpiente", driveId: "1wQJgCbXE77scczyuAEBBmWQviRfSbcIm", desc: "Wu explica por qué Aspheera lo odia tanto." },
    { num: 12, title: "Entrada al Abismo", driveId: "1SPQylc6qIs_lv9crVYXEVXUwiYzvoFPt", desc: "Los Ninja buscan un pergamino en las profundidades del mar." },
    { num: 13, title: "El Protocolo Kaiju", driveId: "1H7sDf8VLRRf31QO4331DeltVtoGsJqSY", desc: "P.I.X.A.L. debe defender la ciudad con su armadura gigante." },
    { num: 14, title: "Corrupción", driveId: "1wgg0dnF4xMok8LM4qyA71jShGRKYA2gi", desc: "El uso del Spinjitzu Prohibido muestra sus peligrosos efectos." },
    { num: 15, title: "Un Mensaje de Esperanza", driveId: "1KBqCRAv1GXFkQzZaxhhFMKiI69juDfz5", desc: "Zane se sacrifica para detener a Aspheera." }
];

const iceEpisodes = [
    { num: 16, title: "El Reino de Nunca Jamás", driveId: "1sTXbtNuDYz47-OtunrIrm4K9fW6s9DOE", desc: "Los Ninja llegan buscando a Zane, pero encuentran un mundo de hielo." },
    { num: 17, title: "Fuego y Hielo", driveId: "1SKuwd_GVKc_p1dHJ7xVihRxCWAinLaMH", desc: "El equipo ayuda a una aldea local contra los guerreros de hielo." },
    { num: 18, title: "El Viaje de Lloyd", driveId: "1k9htORh95FsLSgjZhSwJuCBt7wctetEO", desc: "Lloyd busca el castillo del Emperador y conoce a Akita." },
    { num: 19, title: "El Segundo de a Bordo", driveId: "1gU8Aq7fxZDr5RBm3RRNENX0n_Ta97jeP", desc: "Vex manipula la situación para mantener su poder." },
    { num: 20, title: "Secretos de la Loba", driveId: "1kH9p8qLDGzyfZuhaWJ3orvGebhzzwTLc", desc: "Akita revela su pasado mientras guía a Lloyd." },
    { num: 21, title: "El Último de los Formidables", driveId: "15FGpkVfrfDmj3frT9gcmkjBqehTcsHEZ", desc: "Los Ninja se enfrentan a los generales del ejército de hielo." },
    { num: 22, title: "Mi Amigo, el Enemigo", driveId: "1WcK3AA0b1L5PzigZHcb9FSnFlwuVB6ho", desc: "Lloyd llega al castillo y descubre la identidad del Emperador." },
    { num: 23, title: "La Caída del Maestro", driveId: "1QIAVNHWiGjTskXn3Tbitn6x9YAfowxJF", desc: "El equipo intenta romper el hechizo que corrompió al Emperador." },
    { num: 24, title: "El Ascenso del Dragón", driveId: "1B-PNoP5v3q1c2cxpuA9sKfyPeaFMLE39", desc: "Kai lucha por recuperar sus poderes de fuego." },
    { num: 25, title: "El Despertar", driveId: "15Y7SlM1yu_oHDV-WYBrvdyH9AAAUHIlS", desc: "Zane recupera su memoria y el reino comienza a descongelarse." },
    { num: 26, title: "Protocolo de Mensaje", driveId: "1hcp-jStry75oQgMgc_gg9jcmdkTFo2y8", desc: "P.I.X.A.L. intenta contactar a los Ninja desde Ninjago." },
    { num: 27, title: "El Arrepentimiento de Vex", driveId: "14sSFAFqqtJq2P4ob2zOX09CKiYOa-DUy", desc: "Se exploran las motivaciones de Vex y su rencor." },
    { num: 28, title: "El Hielo de las Almas", driveId: "1GBYfHtjeqYYyQN6_y69AL9PJH_2H1Lfh", desc: "Los Ninja deben enfrentar una última prueba antes de regresar." },
    { num: 29, title: "El Camino de Regreso", driveId: "1j3Rb4si2Glq8rNwnZU8qEXyNvJ17_iJA", desc: "El equipo prepara el viaje de retorno a Ninjago City." },
    { num: 30, title: "Fin de la Aventura", driveId: "1Wnz0xHuKQRXCafVcbCzczTfHYmyCzZ74", desc: "Los Ninja regresan a su hogar listos para nuevos desafíos." }
];
---

<BaseLayout title="Ninjago Temporada 11: Spinjitzu Prohibido | Nexus Stream" activePage="series">
    <!-- Hero Section -->
    <section class="hero" style="background: linear-gradient(to right, rgba(10, 10, 15, 0.9), rgba(10, 10, 15, 0.4)), url('/images/ninjago_temp11.jpg') center/cover;">
        <div class="hero-content">
            <span class="badge" style="background: linear-gradient(to right, #e67e22, #3498db); color: white; border: none;">Temporada 11</span>
            <h1>Secretos del Spinjitzu Prohibido</h1>
            <p>Los Ninja se enfrentan a una antigua hechicera de fuego y viajan a un reino de hielo eterno. Es hora de desbloquear el poder más peligroso: el Spinjitzu Prohibido.</p>
        </div>
    </section>

    <!-- Capítulo de Fuego 🔥 -->
    <section class="content-section">
        <div class="section-header">
            <h2 style="color: #e67e22;"><i class="fa fa-fire"></i> Capítulo de Fuego</h2>
        </div>
        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {fireEpisodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('/images/ninjago_temp11.jpg');`}>
                        <div class="ep-overlay" style="background: rgba(230, 126, 34, 0.2);">
                            <span class="ep-badge" style="background: #e67e22;">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Capítulo de Hielo ❄️ -->
    <section class="content-section">
        <div class="section-header">
            <h2 style="color: #3498db;"><i class="fa fa-snowflake-o"></i> Capítulo de Hielo</h2>
        </div>
        <div class="grid-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            {iceEpisodes.map((ep) => (
                <div class="episode-card" onclick={`updatePlayer(${ep.num-1}, '${ep.title}', '${ep.driveId}')`}>
                    <div class="ep-thumbnail" style={`background-image: url('/images/ninjago_temp11.jpg');`}>
                        <div class="ep-overlay" style="background: rgba(52, 152, 219, 0.2);">
                            <span class="ep-badge" style="background: #3498db;">CAP {ep.num}</span>
                            <i class="fa fa-play-circle"></i>
                        </div>
                    </div>
                    <div class="ep-details">
                        <h4>{ep.title}</h4>
                        <p>{ep.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Reproductor -->
    <section class="content-section" id="player" style="padding-top: 0;">
        <div class="section-header">
            <h2 id="player-title" style="border-left: 4px solid var(--accent); padding-left: 15px;">Selecciona un episodio</h2>
        </div>
        <div class="player-container" style="background: var(--bg-card); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
            <div id="video-wrapper" class="video-responsive" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); flex-direction: column;">
                    <i class="fa fa-play-circle" style="font-size: 64px; margin-bottom: 20px; color: var(--accent);"></i>
                    <p>Dominando los Elementos...</p>
                </div>
            </div>
            <div class="series-controls" style="padding: 20px; background: rgba(0,0,0,0.5); display: flex; justify-content: center; gap: 20px;">
                <a id="download-link" href="#" target="_blank" class="btn-primary"><i class="fa fa-download"></i> Descargar Episodio</a>
            </div>
        </div>
    </section>

    <script is:inline define:vars={{ episodes: [...fireEpisodes, ...iceEpisodes] }}>
        window.updatePlayer = function(index, title, driveId) {
            document.getElementById('player-title').innerText = `Reproduciendo: Ep ${index + 1} - ${title}`;
            document.getElementById('video-wrapper').innerHTML = `<iframe src="https://drive.google.com/file/d/${driveId}/preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border:0;" allowfullscreen></iframe>`;
            document.getElementById('download-link').href = `https://drive.google.com/file/d/${driveId}/view?usp=sharing`;
            
            if (window.trackVideoView) window.trackVideoView();
            window.scrollTo({ top: document.getElementById('player').offsetTop - 100, behavior: 'smooth' });
        }
    </script>

    <style>
        .episode-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            cursor: pointer;
            transition: 0.3s;
        }
        .episode-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .ep-thumbnail {
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .ep-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: 0.3s;
        }
        .episode-card:hover .ep-overlay { opacity: 1; background: rgba(0,0,0,0.1) !important; }
        .ep-badge {
            position: absolute;
            top: 10px; left: 10px;
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }
        .ep-overlay i { font-size: 40px; color: white; }
        .ep-details { padding: 15px; }
        .ep-details h4 { font-size: 15px; margin-bottom: 5px; color: white; }
        .ep-details p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</BaseLayout>
